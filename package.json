  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "typescript": "~5.9.2"
  },
  "private": true
